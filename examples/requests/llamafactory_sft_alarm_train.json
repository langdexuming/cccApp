{
  "name": "Qwen3.5-2B 告警诊断监督微调训练",
  "scene": "告警诊断",
  "base_model": "Qwen/Qwen3.5-2B",
  "trainer_backend": "llamafactory",
  "route_type": "sft",
  "dataset_version": "alarm_analysis_train_v1",
  "evalset_version": "alarm_analysis_eval_v1",
  "prompt_template_version": "alarm_analysis_prompt_v1",
  "train_config": {
    "template": "qwen",
    "learning_rate": 0.0002,
    "num_train_epochs": 1,
    "cutoff_len": 4096,
    "per_device_train_batch_size": 1,
    "gradient_accumulation_steps": 4,
    "lora_rank": 32,
    "lora_alpha": 64,
    "lora_dropout": 0.05
  },
  "infer_config": {
    "auto_gguf": true,
    "gguf_outtype": "f16",
    "skip_ollama": false,
    "skip_eval": false,
    "skip_benchmark": false,
    "keep_alive": "10m",
    "system_prompt": "/no_think\n你是动环监控平台告警诊断助手，请基于告警摘要输出诊断结论、处理建议和成因分析，不要输出无关前言。",
    "parameters": {
      "temperature": 0.1,
      "top_p": 0.8,
      "seed": 42,
      "num_ctx": 8192
    },
    "options": {
      "temperature": 0.1,
      "top_p": 0.8,
      "seed": 42,
      "num_ctx": 8192,
      "num_predict": 512
    }
  }
}
